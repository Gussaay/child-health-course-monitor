{
  "appId": "com.nchp.monitoring.app",
  "appName": "NCHP Monitoring",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "hostname": "com.nchp.monitoring.app"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "launchAutoHide": true
    },
   "Assets": {
      "icon": {
        "path": "public/child.png"
      },
      "splash": {
        "path": "public/splash.png"
      }
    },
    "CapacitorUpdater": {
      "autoUpdate": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}